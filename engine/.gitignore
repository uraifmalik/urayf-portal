.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover

# ─── Linter caches ────────────────────────────────────────────────────────
.ruff_cache/
.mypy_cache/

# ─── IDE ──────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ─── OS ───────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

