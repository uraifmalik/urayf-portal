# ------------------------------------------------------------
# Urayf Portal — environment variables
# Copy this file to `.env.local` and fill in the values.
# In Vercel, add the same two variables under Project Settings → Environment Variables.
# ------------------------------------------------------------

# Supabase → Project Settings → Data API / API Keys
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Leaving these blank runs the portal in demo mode (sample data, no auth).
